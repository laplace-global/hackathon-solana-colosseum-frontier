# Database
# Neon pooled connection string.
# keep Neon credentials secure: do not expose them to client-side code
DATABASE_URL=

# Solana RPC
# Keep API-keyed RPC URLs server-only unless the provider endpoint is explicitly restricted for browser use.
SOLANA_RPC_URL=

# Protocol wallet secrets
# Values are bs58-encoded Solana keypair secrets.
TREASURY_WALLET_SECRET=
OPERATOR_WALLET_SECRET=

# Optional Reserve wallet for auto-replenishing Treasury SOL on devnet.
RESERVE_WALLET_SECRET=
TREASURY_SOL_MINIMUM=5
TREASURY_SOL_TARGET=20
